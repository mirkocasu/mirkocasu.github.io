<ul class="card-text font-weight-light list-group list-group-flush">
  {% assign volunteer = data[1] | sort: 'startDate' | reverse %}
  {% for content in volunteer %}
    {% capture date %}{% include shared/date_value.liquid start=content.startDate end=content.endDate mode='range' %}{% endcapture %}
    {% assign date = date | strip %}
    <li class="list-group-item">
      <div class="row">
        {% include shared/date_column.liquid date=date location=content.location %}
        <div class="col-xs-10 cl-sm-10 col-md-10 mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            <a href="{{ content.url }}">{{ content.position }}</a>
          </h6>
          <h6 class="ml-1 ml-md-4 cv-secondary-text">{{ content.organization }}</h6>
          <h6 class="ml-1 ml-md-4 cv-secondary-text cv-secondary-text-italic">{{ content.summary }}</h6>
          {% include shared/content_list.liquid items=content.highlights %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
