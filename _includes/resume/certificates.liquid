<div class="list-groups">
  {% assign certificates = data[1] | sort: 'date' | reverse %}
  {% for content in certificates %}
    {% assign colspan = 2 %}
    <div class="list-group col-md-6">
      <table class="table-cv list-group-table">
        <tbody>
          {% include shared/list_group_header.liquid title=content.name url=content.url icon=content.icon colspan=colspan %}
          <tr>
            <td></td>
            <td class="list-group-name">
              <b>{{ content.issuer }}</b>
            </td>
            <td class="list-group-name">{{ content.date }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  {% endfor %}
</div>
