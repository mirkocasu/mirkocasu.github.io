<ul class="card-text font-weight-light list-group list-group-flush">
  {% assign publications = data[1] | sort: 'releaseDate' | reverse %}
  {% for content in publications %}
    {% capture date %}{% include shared/date_value.liquid value=content.releaseDate mode='date' %}{% endcapture %}
    {% assign date = date | strip %}
    <li class="list-group-item">
      <div class="row">
        {% include shared/date_column.liquid date=date %}
        <div class="col-xs-10 cl-sm-10 col-md-10 mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            <a href="{{ content.url }}">{{ content.name }}</a>
          </h6>
          <h6 class="ml-1 ml-md-4 cv-secondary-text">{{ content.publisher }}</h6>
          <h6 class="ml-1 ml-md-4 cv-secondary-text cv-secondary-text-italic">{{ content.summary }}</h6>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
