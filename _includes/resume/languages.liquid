<div class="list-groups">
  {% for content in data[1] %}
    <div class="list-group col-md-6">
      <table class="table-cv list-group-table">
        <tbody>
          {% include shared/list_group_header.liquid title=content.language icon=content.icon colspan=1 %}
          <tr>
            <td></td>
            <td class="list-group-name">
              <b>{{ content.fluency }}</b>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  {% endfor %}
</div>
