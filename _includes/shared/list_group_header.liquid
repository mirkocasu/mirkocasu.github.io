<tr>
  {% if include.icon %}
    <td class="list-group-category-icon">
      <i class="{{ include.icon }}"></i>
    </td>
  {% else %}
    <td class="list-group-category-icon"></td>
  {% endif %}
  <td colspan="{{ include.colspan | default: 1 }}" class="list-group-category">
    {% if include.url %}
      <a href="{{ include.url }}">{{ include.title }}</a>
    {% else %}
      {{ include.title }}
    {% endif %}
  </td>
</tr>
